__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Working scratch files at repo root (audit-pass tmp scripts, draft
# manuscript snapshots, sanity-check probes). Strict pattern at the
# repo root so a stray `git add -A` cannot leak a draft manuscript or
# diagnostic script into the GitHub history. The user's working
# .tmp_paper.md draft is matched here too.
/.tmp_*

# HPC pipeline outputs. The slurm orchestrator writes per-job stdout
# / stderr into ``logs/`` and the aggregator's last step produces
# ``hpc_results_<RUN_TAG>.tar.gz`` at the repo root. Both are
# transient run artefacts that should not enter the GitHub history;
# keeping them gitignored keeps the dirty-tree check in
# build_artifact_manifest.py focused on actual uncommitted code
# changes rather than expected run output.
/logs/
/hpc_results_*.tar.gz

# Stochastic feasibility test scripts (diagnostic, not production)
docs/screenshots/_check/
node_modules/
dist/
.venv/
*.egg-info/

# IDE / editor
.vscode/
.idea/
.claude/
.vite/

# Hardhat build artifacts
**/hardhat/artifacts/
**/hardhat/cache/
# Stale top-level Hardhat build dir (pre-2026-05). Removed from the
# tree because the canonical Hardhat artifacts location is
# agribrain/contracts/hardhat/artifacts/ (covered by the rule above).
# Listed here so a future ``npx hardhat compile`` from the wrong cwd
# cannot resurrect the duplicate.
agribrain/build/

# Environment and secrets
.env
.env.local
.env.production
.envrc

# Cryptographic keys and credentials — broad patterns so an operator
# cloning the repo and running an on-chain experiment cannot
# accidentally `git add -A` a private keypair or token file.
*.pem
*.key
*.keystore
*.p12
*.pfx
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
*.gpg
*.kdbx
secrets.json
secrets.yaml
credentials.json
service-account*.json

# HPC artifacts (the hpc_*.sh scripts are tracked)
hpc_import.sh
hpc_results.tar.gz
hpc_results_*.tar.gz
agribrain-repro-*.out
agribrain-repro-*.err
logs/

# Experiment run outputs (regenerated by backend/experiments/run_experiments.py)
agribrain/backend/experiments/out/

# PiRAG vector store persistence
*.vectorstore
pirag_vectors/
agribrain/backend/src/data_spinach_v1.csv

# Simulation results: keep canonical tables + figures, ignore volatile runtime outputs
mvp/simulation/results/*
!mvp/simulation/results/table1_summary.csv
!mvp/simulation/results/table2_ablation.csv
!mvp/simulation/results/benchmark_summary.json
!mvp/simulation/results/benchmark_significance.json
!mvp/simulation/results/stress_summary.json
!mvp/simulation/results/stress_degradation.csv
!mvp/simulation/results/feature_heatmap_data.json
!mvp/simulation/results/artifact_manifest.json
!mvp/simulation/results/fig*.png
!mvp/simulation/results/fig*.pdf
