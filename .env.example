# =========================================================================
# WARNING: These are DEVELOPMENT defaults. For production, set at minimum:
#   APP_ENV=prod
#   REQUIRE_API_KEY=true
#   APP_API_KEY=<strong-random-key>
#   CORS_ORIGINS=https://your-domain.com
#   ENABLE_DEBUG_ROUTES=false
#   WS_REQUIRE_API_KEY=true
#   WS_API_KEY=<strong-random-key>
# Additional production hardening:
#   - Do NOT send CHAIN_PRIVKEY via POST /chain/config in a shared proxy
#     environment; set it via env so it never enters an HTTP request body.
#   - Terminate TLS in front of the API; the FastAPI server is not TLS.
#   - Restrict CORS_ORIGINS to your known frontend origin(s).
#   - Disable the demo /admin debug routes by setting ENABLE_DEBUG_ROUTES=false.
# =========================================================================
APP_ENV=dev
CORS_ORIGINS=*
REQUIRE_API_KEY=false
APP_API_KEY=
ALLOW_LOCAL_WITHOUT_API_KEY=true
ENABLE_DEBUG_ROUTES=true
WS_REQUIRE_API_KEY=false
WS_API_KEY=
CHAIN_REQUIRE_PRIVKEY=true
# Signing key used by the Python on-chain client when POST /chain/config has
# not been called with an explicit private_key. Loaded via env as a fallback
# only; the HTTP /chain/config endpoint redacts the key to a presence flag
# ("set" / "unset") in its response so keys never cross proxy boundaries.
# Leave empty when not anchoring on-chain.
CHAIN_PRIVKEY=
# HTTP RPC endpoint for on-chain calls. Example: http://127.0.0.1:8545 for
# a local Hardhat node. Leave empty to disable on-chain submission.
CHAIN_RPC=
# Deployed DecisionLogger address. Populated automatically when the Hardhat
# deploy script writes backend/runtime/chain/deployed-addresses.*.json and
# auto-loading is enabled.
CHAIN_DECISION_LOGGER=

FORECAST_METHOD=lstm
ONLINE_LEARNING=false
LLM_PROVIDER=template
DATA_CSV=
SIM_API_BASE=http://127.0.0.1:8100
RAG_CONTEXT_ENABLED=true

# Stochastic simulation — 7 realistic uncertainty sources
# Set DETERMINISTIC_MODE=true for exact bit-for-bit reproducibility (audit mode)
DETERMINISTIC_MODE=false
# Source 1: Sensor noise
STOCH_TEMP_STD_C=1.5
STOCH_RH_STD=5.0
# Source 2: Demand variability
STOCH_DEMAND_FRAC_STD=0.18
# Source 3: Inventory/yield uncertainty
STOCH_INVENTORY_FRAC_STD=0.15
# Source 4: Transport distance jitter
STOCH_TRANSPORT_KM_STD=0.15
# Source 5: Spoilage model error (batch-to-batch biological variability)
STOCH_K_REF_STD=0.15
STOCH_EA_R_STD=0.10
# Source 6: Scenario onset timing jitter
STOCH_ONSET_JITTER_H=4.0
# Source 7: Policy weight perturbation
STOCH_THETA_NOISE_STD=0.03
# Telemetry lag (intermittent dropouts)
STOCH_DELAY_PROB=0.05

# Experiment toggles
MCP_QOS_ROUTING=false
MCP_RELIABILITY=false
PIRAG_COUNTERFACTUAL=false
PHYSICS_CONSISTENCY_GATE=false
HETEROGENEOUS_PROFILES=false
RESEARCH_METRICS=false
FAILURE_INJECTION=false
BENCHMARK_SEEDS=42,1337,2024,7,99,101,202,303,404,505,606,707,808,909,1010,1111,1212,1313,1414,1515

