# =========================================================================
# AGRI-BRAIN production environment template.
#
# Use this file as the starting point for production deployments. The
# defaults below are the SAFE values; copy this file to `.env`, fill in
# the credentials, and never commit the populated `.env`.
#
# The companion file `.env.example` is the DEV template (open CORS, no
# API key, debug routes on). Do NOT copy `.env.example` into production
# and expect the harness to be safe.
# =========================================================================
APP_ENV=prod
CORS_ORIGINS=https://example.com
REQUIRE_API_KEY=true
APP_API_KEY=__set_to_strong_random_64_chars_here__
ALLOW_LOCAL_WITHOUT_API_KEY=false
ENABLE_DEBUG_ROUTES=false
WS_REQUIRE_API_KEY=true
WS_API_KEY=__set_to_strong_random_64_chars_here__

# On-chain signing key. ALWAYS set via env; never POST /chain/config with
# a key in the body in production (TLS termination is upstream and the
# server logs may capture POST bodies on a misconfigured proxy).
CHAIN_REQUIRE_PRIVKEY=true
CHAIN_PRIVKEY=
CHAIN_RPC=
CHAIN_DECISION_LOGGER=
# Best-effort anchoring: when true, on-chain submission failures are
# logged at WARN and submit_onchain returns None. When false (the
# production default), failures raise so operators do not silently
# believe an anchoring happened when it did not.
CHAIN_BEST_EFFORT=false

FORECAST_METHOD=lstm
ONLINE_LEARNING=false
LLM_PROVIDER=template
DATA_CSV=
SIM_API_BASE=
RAG_CONTEXT_ENABLED=true

DETERMINISTIC_MODE=false
STOCH_TEMP_STD_C=1.5
STOCH_RH_STD=5.0
STOCH_DEMAND_FRAC_STD=0.18
STOCH_INVENTORY_FRAC_STD=0.15
STOCH_TRANSPORT_KM_STD=0.15
STOCH_K_REF_STD=0.15
STOCH_EA_R_STD=0.10
STOCH_ONSET_JITTER_H=4.0
STOCH_THETA_NOISE_STD=0.03
STOCH_DELAY_PROB=0.05

# Experiment toggles. All off by default in prod; the published HPC
# benchmark scripts set the ones it needs explicitly.
MCP_QOS_ROUTING=false
MCP_RELIABILITY=false
PIRAG_COUNTERFACTUAL=false
PHYSICS_CONSISTENCY_GATE=false
HETEROGENEOUS_PROFILES=false
RESEARCH_METRICS=false
FAILURE_INJECTION=false

# Strict validator gate (default in 2026-04+). Range/interval checks
# block the build; ordering claims are reported as warnings only.
STRICT_VALIDATION=1

# piRAG dynamic-knowledge feedback: keep OFF in production runs that
# you publish, because the loop re-ingests the agent's own actions as
# documents. Enable only for ablation studies that report with/without.
DYNAMIC_KB_FEEDBACK=false
