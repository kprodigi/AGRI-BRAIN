# =========================================================================
# AGRI-BRAIN production environment template.
#
# Use this file as the starting point for production deployments. The
# defaults below are the SAFE values; copy this file to `.env`, fill in
# the credentials, and never commit the populated `.env`.
#
# The companion file `.env.example` is the DEV template (open CORS, no
# API key, debug routes on). Do NOT copy `.env.example` into production
# and expect the harness to be safe.
# =========================================================================
APP_ENV=prod
CORS_ORIGINS=https://example.com
REQUIRE_API_KEY=true
APP_API_KEY=__set_to_strong_random_64_chars_here__
ALLOW_LOCAL_WITHOUT_API_KEY=false
ENABLE_DEBUG_ROUTES=false
WS_REQUIRE_API_KEY=true
WS_API_KEY=__set_to_strong_random_64_chars_here__
# Gate /docs /redoc /openapi.json behind the API-key middleware so an
# unauthenticated GET /openapi.json cannot enumerate the full route
# schema for reconnaissance. Disable only when docs are terminated
# upstream (reverse proxy, IP allowlist, etc.).
PROTECT_DOCS=true
# Scoped API keys. Each one limits the blast radius of a single
# leaked credential: the governance key only authorises governance
# routes, the chain key only authorises chain routes, etc. When unset
# they fall back to APP_API_KEY so single-key deployments keep
# working; production should set distinct strong random values.
GOVERNANCE_API_KEY=__set_to_strong_random_64_chars_here__
CHAIN_API_KEY=__set_to_strong_random_64_chars_here__
PHASE_API_KEY=__set_to_strong_random_64_chars_here__
MCP_API_KEY=__set_to_strong_random_64_chars_here__

# On-chain signing key. ALWAYS set via env; never POST /chain/config with
# a key in the body in production (TLS termination is upstream and the
# server logs may capture POST bodies on a misconfigured proxy).
CHAIN_REQUIRE_PRIVKEY=true
CHAIN_PRIVKEY=
CHAIN_RPC=
CHAIN_DECISION_LOGGER=
# Best-effort anchoring: when true, on-chain submission failures are
# logged at WARN and submit_onchain returns None. When false (the
# production default), failures raise so operators do not silently
# believe an anchoring happened when it did not.
CHAIN_BEST_EFFORT=false

FORECAST_METHOD=lstm
ONLINE_LEARNING=false
LLM_PROVIDER=template
DATA_CSV=
SIM_API_BASE=
RAG_CONTEXT_ENABLED=true

# Frontend build-time API base. Set this to your prod backend URL so
# ``npm run build`` produces a bundle that talks to the right host
# without relying on window.API_BASE injection or per-browser
# localStorage. Required for non-localhost prod deployments.
VITE_API_BASE=https://api.example.com

DETERMINISTIC_MODE=false
# Match the README's documented stochastic-CV envelope (see
# .env.example for the per-source rationale).
STOCH_TEMP_STD_C=2.5
STOCH_RH_STD=7.0
STOCH_DEMAND_FRAC_STD=0.25
STOCH_INVENTORY_FRAC_STD=0.22
STOCH_TRANSPORT_KM_STD=0.22
STOCH_K_REF_STD=0.20
STOCH_EA_R_STD=0.14
STOCH_ONSET_JITTER_H=6.0
STOCH_THETA_NOISE_STD=0.15
STOCH_DELAY_PROB=0.10

# Experiment toggles. All off by default in prod; the published HPC
# benchmark scripts set the ones it needs explicitly.
MCP_QOS_ROUTING=false
MCP_RELIABILITY=false
PIRAG_COUNTERFACTUAL=false
PHYSICS_CONSISTENCY_GATE=false
HETEROGENEOUS_PROFILES=false
RESEARCH_METRICS=false
FAILURE_INJECTION=false

# Strict validator gate (default in 2026-04+). Range/interval checks
# block the build; ordering claims are reported as warnings only.
STRICT_VALIDATION=1

# piRAG dynamic-knowledge feedback: keep OFF in production runs that
# you publish, because the loop re-ingests the agent's own actions as
# documents. Enable only for ablation studies that report with/without.
DYNAMIC_KB_FEEDBACK=false

# Reproducibility provenance (HPC pipeline-set; see HOW_TO_RUN.md).
# Set RUN_TAG and AGRIBRAIN_GIT_COMMIT on the HPC login node so they
# propagate to the slurm worker through sbatch --export. Set
# DECISION_LEDGER_DIR per-task (see hpc/hpc_seed.sh) so the 20 parallel
# array tasks do not race-overwrite each other.
#RUN_TAG=
#AGRIBRAIN_GIT_COMMIT=
#AGRIBRAIN_ALLOW_DIRTY=0
#DECISION_LEDGER_DIR=

# Blockchain runtime. CHAIN_PRIVKEY MUST come from a runtime secret
# store (Vault / sealed-secret / SSM Parameter Store) in production --
# never check it into a committed .env file. The default chain_id and
# RPC point at a Hardhat node; for testnet replace with the provider
# URL and the matching chain_id (Sepolia=11155111, Polygon Amoy=80002).
#CHAIN_PRIVKEY=
#CHAIN_RPC=http://127.0.0.1:8545
